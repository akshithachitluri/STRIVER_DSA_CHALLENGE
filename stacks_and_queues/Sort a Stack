class Solution {
  public:
    void sortStack(stack<int> &st) {
        vector<int>result;
        while(!st.empty()){
            result.push_back(st.top());
            st.pop();
        }
        sort(result.begin(),result.end());
        int n = result.size();
        for(int i = 0;i<n;i++){
            st.push(result[i]);
        }
    }
};  
