#include <bits/stdc++.h>
using namespace std;

bool isPalindrome(string &s, int start, int end) {
    while (start < end) {
        if (s[start] != s[end])
            return false;
        start++;
        end--;
    }
    return true;
}

void solve(int idx, string &s, vector<string> &path,
           vector<vector<string>> &ans) {

    if (idx == s.size()) {
        ans.push_back(path);
        return;
    }

    for (int i = idx; i < s.size(); i++) {

        if (isPalindrome(s, idx, i)) {

            path.push_back(s.substr(idx, i - idx + 1));

            solve(i + 1, s, path, ans);

            path.pop_back();
        }
    }
}

int main() {

    string s;
    cin >> s;

    vector<vector<string>> ans;
    vector<string> path;

    solve(0, s, path, ans);

    for (auto &partition : ans) {
        for (auto &str : partition) {
            cout << str << " ";
        }
        cout << endl;
    }

    return 0;
}
