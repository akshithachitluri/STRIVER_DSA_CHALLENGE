/* Node structure  used in the program

struct Node{
    int data;
    struct Node * next;
    struct Node * bottom;

    Node(int x){
        data = x;
        next = NULL;
        bottom = NULL;
    }

};
*/

class Solution {
  public:
  Node* merge2lists(Node* list1,Node* list2){
      Node* dummy = new Node(-1);
      Node* res = dummy;
      while(list1!=nullptr && list2!=nullptr){
          if(list1->data < list2->data){
              res->bottom = list1;
              res = list1;
              list1 = list1->bottom;
          }else{
              res->bottom = list2;
              res = list2;
              list2 = list2->bottom;
          }
          res->next = nullptr;
      }
      if(list1) res->bottom = list1;
      else res->bottom = list2;
      return dummy->bottom;
  }
    Node *flatten(Node *root) {
        if(root == nullptr || root->next == nullptr) return root;
        Node* mergedhead = flatten(root->next);
        return merge2lists(root,mergedhead);
    }
};
